<script is:inline>
// ══ DATA ══
const COLUMNS = [
  { id:'ql', label:'Quest Labs', color:'#7C3AED' },
  { id:'school', label:'School Work', color:'#0D9488' },
  { id:'work', label:'Work / Research', color:'#BE123C' },
  { id:'home', label:'Home', color:'#D97706' },
  { id:'joy', label:'Joy of Being', color:'#A78BFA' },
];

const SP_VALUES = [1, 2, 3, 5, 8, 13, 21];

// Default cells — empty board on first run
const DEFAULT_CELLS = [];


const WOL_AREAS = [
  { label: 'Digital Diet', color: '#7C3AED' },
  { label: 'Organization', color: '#0D9488' },
  { label: 'Friends', color: '#BE123C' },
  { label: 'Family', color: '#D97706' },
  { label: 'Relationships', color: '#EC4899' },
  { label: 'School-work', color: '#A78BFA' },
  { label: 'Fun / Play', color: '#CCFBF1' },
  { label: 'Health', color: '#FEF3C7' },
  { label: 'Growth', color: '#EDE9FE' },
];

const COL_CLASSES = ['ql-col','school-col','work-col','home-col','joy-col'];
const COL_ID_TO_IDX = { ql:0, school:1, work:2, home:3, joy:4 };
const COL_XP = [25, 20, 20, 15, 30];


// ══ STATE ══
// cells: [{ text, xp, done, col }]  col = 0-4 (grid column) or -1 (overflow)
let state = {
  name: '',
  xp: 0,
  xpLog: [],
  cells: [],
  overflow: [],   // kept for migration only
  archive: [],    // [{ text, xp, col, archivedAt }]
  wheel: [3,3,3,3,3,3,3,3,3],
  wheelHistory: [],
};

function makeDefaultCells() {
  return DEFAULT_CELLS.map(c => ({ ...c }));
}

// ── INIT ──
async function init() {
  state.cells = makeDefaultCells();
  await loadStateFromDB();
  renderQuestCard();
  renderWheelSliders();
  renderWheel();
  setDate();
  updateIdentity();
  initNameEdit();
}

function setDate() {
  const d = new Date();
  document.getElementById('qc-date').textContent = d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
}

// ── TABS ──
function switchTab(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}

// ── NAME (inline edit) ──
function initNameEdit() {
  const el = document.getElementById('qc-name');
  el.addEventListener('blur', () => {
    const name = el.textContent.trim();
    state.name = name || 'Questor';
    if (!name) el.textContent = 'Questor';
    saveState();
  });
  el.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); el.blur(); }
    if (e.key === 'Escape') { el.textContent = state.name || 'Questor'; el.blur(); }
  });
  // Close card editor on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeCardEditor();
    if (e.key === 'Enter' && document.getElementById('ce-overlay').style.display !== 'none') {
      if (document.activeElement === document.getElementById('ce-title')) saveCardEditor();
    }
  });
}

function updateIdentity() {
  const el = document.getElementById('qc-name');
  if (document.activeElement !== el) {
    el.textContent = state.name || 'Questor';
  }
  updateXPDisplay();
}

// ── QUEST CARD RENDER ──
function renderQuestCard() {
  const grid = document.getElementById('qc-grid');
  grid.innerHTML = '';

  // Build 5 column lanes
  for (let colIdx = 0; colIdx < 5; colIdx++) {
    const lane = document.createElement('div');
    lane.className = 'qc-col-lane';
    lane.dataset.col = colIdx;

    state.cells.forEach((cell, i) => {
      if (cell.col === colIdx) lane.appendChild(createGridCard(cell, i));
    });

    lane.addEventListener('dragover', e => { e.preventDefault(); lane.classList.add('drag-over'); });
    lane.addEventListener('dragleave', e => { if (!lane.contains(e.relatedTarget)) lane.classList.remove('drag-over'); });
    lane.addEventListener('drop', e => handleDropOnCol(e, colIdx));

    const addBtn = document.createElement('button');
    addBtn.className = 'col-add-btn';
    addBtn.innerHTML = '+ Add card';
    addBtn.onclick = () => addCardToColumn(colIdx);
    lane.appendChild(addBtn);

    grid.appendChild(lane);
  }

  renderOverflow();
  updateXPDisplay();
}

function createGridCard(cell, idx) {
  const div = document.createElement('div');
  const colIdx = cell.col >= 0 ? cell.col : 0;
  div.className = `qc-cell ${COL_CLASSES[colIdx]} ${cell.done ? 'done' : ''}`;
  div.dataset.idx = idx;
  div.draggable = true;
  const sp = cell.storyPoints || 1;
  div.innerHTML = `
    <span class="cell-star">★</span>
    <button class="cell-edit-btn" title="Edit task">✎</button>
    <div class="cell-text">${cell.text}</div>
    <div class="sp-badge">SP ${sp}</div>
  `;

  div.addEventListener('click', e => {
    if (e.target.closest('.cell-edit-btn')) return;
    toggleCell(idx);
  });
  div.querySelector('.cell-edit-btn').addEventListener('click', e => {
    e.stopPropagation();
    openCardEditor(idx);
  });

  div.addEventListener('dragstart', e => {
    e.dataTransfer.setData('text/plain', JSON.stringify({ type: 'cell', idx }));
    e.dataTransfer.effectAllowed = 'move';
    setTimeout(() => div.classList.add('dragging'), 0);
  });
  div.addEventListener('dragend', () => {
    div.classList.remove('dragging');
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
  });

  return div;
}

function renderOverflow() {
  const og = document.getElementById('overflow-grid');
  og.innerHTML = '';

  state.cells.forEach((cell, i) => {
    if (cell.col !== -1) return;
    const card = document.createElement('div');
    const sp = cell.storyPoints || 1;
    card.className = `qc-cell ql-col ${cell.done ? 'done' : ''}`;
    card.style.cssText = 'border-color:rgba(124,58,237,0.2);background:rgba(124,58,237,0.05);';
    card.dataset.idx = i;
    card.draggable = true;
    card.innerHTML = `
      <span class="cell-star">★</span>
      <button class="cell-edit-btn" title="Edit task">✎</button>
      <div class="cell-text">${cell.text}</div>
      <div class="sp-badge">SP ${sp}</div>
    `;

    card.addEventListener('click', e => {
      if (e.target.closest('.cell-edit-btn')) return;
      state.cells[i].done = !state.cells[i].done;
      const xpVal = (state.cells[i].storyPoints || 1) * 10;
      if (state.cells[i].done) {
        addXP(xpVal, state.cells[i].text);
      } else {
        state.xp = Math.max(0, state.xp - xpVal);
        updateXPDisplay();
      }
      renderQuestCard();
      saveState();
    });
    card.querySelector('.cell-edit-btn').addEventListener('click', e => {
      e.stopPropagation();
      openCardEditor(i);
    });

    card.addEventListener('dragstart', e => {
      e.dataTransfer.setData('text/plain', JSON.stringify({ type: 'cell', idx: i }));
      e.dataTransfer.effectAllowed = 'move';
      setTimeout(() => card.classList.add('dragging'), 0);
    });
    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    });

    og.appendChild(card);
  });

  const addBtn = document.createElement('button');
  addBtn.className = 'add-overflow';
  addBtn.textContent = '+ add sidequest';
  addBtn.onclick = addOverflow;
  og.appendChild(addBtn);

  // Wire overflow drop zone
  og.addEventListener('dragover', e => { e.preventDefault(); og.classList.add('drag-over'); });
  og.addEventListener('dragleave', e => { if (!og.contains(e.relatedTarget)) og.classList.remove('drag-over'); });
  og.addEventListener('drop', e => handleDropOnOverflow(e));
}

function handleDropOnCol(e, targetCol) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  try {
    const data = JSON.parse(e.dataTransfer.getData('text/plain'));
    if (data.type === 'cell') {
      state.cells[data.idx].col = targetCol;
      renderQuestCard();
      saveState();
    }
  } catch(_) {}
}

function handleDropOnOverflow(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  try {
    const data = JSON.parse(e.dataTransfer.getData('text/plain'));
    if (data.type === 'cell' && state.cells[data.idx].col !== -1) {
      state.cells[data.idx].col = -1;
      renderQuestCard();
      saveState();
    }
  } catch(_) {}
}

function toggleCell(i) {
  state.cells[i].done = !state.cells[i].done;
  const xpVal = (state.cells[i].storyPoints || 1) * 10;
  if (state.cells[i].done) {
    addXP(xpVal, state.cells[i].text);
  } else {
    state.xp = Math.max(0, state.xp - xpVal);
    updateXPDisplay();
  }
  renderQuestCard();
  saveState();
}

// ── CARD EDITOR ──
let _editingIdx = null;
let _activeSP = 1;
let _isNewCard = false;

function addCardToColumn(col) {
  state.cells.push({ text: '', storyPoints: 1, xp: 10, description: '', done: false, col });
  renderQuestCard();
  openCardEditor(state.cells.length - 1, true);
}

function openCardEditor(idx, isNew = false) {
  _editingIdx = idx;
  _isNewCard = isNew;
  const cell = state.cells[idx];
  document.getElementById('ce-title').value = cell.text || '';
  document.getElementById('ce-title').placeholder = 'Task name';
  document.getElementById('ce-desc').value = cell.description || '';
  buildSPButtons(cell.storyPoints || 1);
  document.getElementById('ce-overlay').style.display = 'flex';
  document.getElementById('ce-title').focus();
}

function closeCardEditor() {
  if (_isNewCard && _editingIdx !== null) {
    state.cells.splice(_editingIdx, 1);
    renderQuestCard();
  }
  document.getElementById('ce-overlay').style.display = 'none';
  _editingIdx = null;
  _isNewCard = false;
}

function ceOverlayClick(e) {
  if (e.target === document.getElementById('ce-overlay')) closeCardEditor();
}

function buildSPButtons(activeSP) {
  _activeSP = activeSP;
  const row = document.getElementById('ce-sp-row');
  row.innerHTML = '';
  SP_VALUES.forEach(sp => {
    const btn = document.createElement('button');
    btn.className = 'ce-sp-btn' + (sp === activeSP ? ' active' : '');
    btn.textContent = sp;
    btn.dataset.sp = sp;
    btn.type = 'button';
    btn.onclick = () => {
      _activeSP = sp;
      row.querySelectorAll('.ce-sp-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.sp) === sp));
    };
    row.appendChild(btn);
  });
}

function saveCardEditor() {
  if (_editingIdx === null) return;
  const title = document.getElementById('ce-title').value.trim();
  if (!title) { closeCardEditor(); return; }
  const desc  = document.getElementById('ce-desc').value.trim();
  state.cells[_editingIdx].text        = title;
  state.cells[_editingIdx].description = desc;
  state.cells[_editingIdx].storyPoints = _activeSP;
  state.cells[_editingIdx].xp          = _activeSP * 10;
  _isNewCard = false;
  renderQuestCard();
  saveState();
  closeCardEditor();
}

function addOverflow() {
  state.cells.push({ text: '', storyPoints: 1, xp: 10, description: '', done: false, col: -1 });
  renderQuestCard();
  openCardEditor(state.cells.length - 1, true);
}

// ── XP ──
function addXP(amount, label) {
  state.xp += amount;
  state.xpLog.unshift({ amount, label, time: new Date().toLocaleTimeString() });
  updateXPDisplay();
  saveState();
}

function updateXPDisplay() {
  const xp = state.xp;
  const level = Math.floor(xp / 500) + 1;
  document.getElementById('qc-xp-display').textContent = xp;
  const pct = Math.min((xp % 500) / 500 * 100, 100);
  document.getElementById('xp-fill').style.width = pct + '%';
  document.getElementById('xp-bar-text').textContent = `${xp % 500} / 500 XP to next level`;
  const levelEl = document.getElementById('qc-level');
  if (levelEl) levelEl.textContent = `Level ${level}`;
}

function exportCard() {
  const done = state.cells.filter(c => c.done).map(c => c.text);
  const text = `Quest Card — ${state.name}\nXP: ${state.xp}\nCompleted: ${done.join(', ') || 'none yet'}`;
  navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard!'));
}

function resetCard() {
  document.getElementById('reset-overlay').style.display = 'flex';
}

function closeResetModal() {
  document.getElementById('reset-overlay').style.display = 'none';
}

function confirmReset(clearXP) {
  state.cells = makeDefaultCells();
  if (clearXP) {
    state.xp = 0;
    state.xpLog = [];
  }
  closeResetModal();
  renderQuestCard();
  renderArchive();
  updateXPDisplay();
  saveState();
}

// ── ARCHIVE ──
function archiveCompleted() {
  const completed = state.cells.filter(c => c.done);
  if (!completed.length) return;
  const now = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  completed.forEach(c => {
    state.archive.unshift({ text: c.text, xp: c.xp, col: c.col, archivedAt: now });
  });
  state.cells = state.cells.filter(c => !c.done);
  renderQuestCard();
  renderArchive();
  saveState();
}

function toggleArchive() {
  const grid = document.getElementById('archive-grid');
  const chevron = document.getElementById('archive-chevron');
  const open = grid.style.display === 'none';
  grid.style.display = open ? 'flex' : 'none';
  chevron.classList.toggle('open', open);
}

function clearArchive(e) {
  e.stopPropagation();
  if (!state.archive.length) return;
  if (!confirm('Permanently delete all archived cards?')) return;
  state.archive = [];
  renderArchive();
  saveState();
}

function renderArchive() {
  const count = document.getElementById('archive-count');
  const grid = document.getElementById('archive-grid');
  if (!count || !grid) return;
  count.textContent = state.archive.length;

  const COL_COLORS = ['#7C3AED','#0D9488','#BE123C','#D97706','#A78BFA'];
  grid.innerHTML = '';
  if (!state.archive.length) {
    grid.innerHTML = '<div style="font-family:\'Space Mono\',monospace;font-size:0.55rem;color:rgba(13,148,136,0.4);padding:0.5rem 0;">No archived cards yet.</div>';
    return;
  }
  state.archive.forEach((card, i) => {
    const div = document.createElement('div');
    div.className = 'archive-card';
    const dotColor = COL_COLORS[card.col >= 0 ? card.col : 0];
    div.innerHTML = `
      <div class="archive-col-dot" style="background:${dotColor}"></div>
      <div class="archive-card-text">${card.text}</div>
      <div class="archive-card-date">${card.archivedAt}</div>
      <button class="archive-card-restore" title="Restore to board" onclick="restoreArchived(${i})">↩</button>
    `;
    grid.appendChild(div);
  });
}

function restoreArchived(i) {
  const card = state.archive[i];
  state.cells.push({ text: card.text, xp: card.xp, done: false, col: card.col >= 0 ? card.col : 0 });
  state.archive.splice(i, 1);
  renderQuestCard();
  renderArchive();
  saveState();
}

// ── WHEEL OF LIFE ──
function renderWheelSliders() {
  const wrap = document.getElementById('wol-sliders');
  wrap.innerHTML = '';
  const title = document.createElement('div');
  title.style.cssText = "font-family:'Playfair Display',serif;font-style:italic;font-size:1rem;font-weight:600;margin-bottom:0.5rem;color:#EDE9FE;";
  title.textContent = 'Set your numbers';
  wrap.appendChild(title);

  WOL_AREAS.forEach((area, i) => {
    const row = document.createElement('div');
    row.className = 'wol-slider-row';
    const color = area.color;
    row.innerHTML = `
      <div class="wol-area-label">
        <div class="wol-dot" style="background:${color};"></div>
        ${area.label}
      </div>
      <input type="range" class="wol-slider" min="1" max="5" step="1"
        value="${state.wheel[i]}" id="wol-slider-${i}"
        oninput="updateWheel(${i}, this.value)">
      <div class="wol-val" id="wol-val-${i}">${state.wheel[i]}</div>
    `;
    wrap.appendChild(row);
  });

  const notice = document.createElement('div');
  notice.className = 'wol-notice';
  notice.id = 'wol-notice';
  notice.textContent = 'What do you notice?';
  wrap.appendChild(notice);
}

function updateWheel(i, val) {
  state.wheel[i] = parseInt(val);
  document.getElementById(`wol-val-${i}`).textContent = val;
  renderWheel();
  updateWheelNotice();
  saveState();
}

function updateWheelNotice() {
  const vals = state.wheel;
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const minArea = WOL_AREAS[vals.indexOf(min)].label;
  const maxArea = WOL_AREAS[vals.indexOf(max)].label;
  const avg = (vals.reduce((a,b)=>a+b,0)/vals.length).toFixed(1);
  const noticeEl = document.getElementById('wol-notice');
  if (noticeEl) {
    noticeEl.textContent = `Your wheel averages ${avg}/5. Highest: ${maxArea} (${max}). Needs attention: ${minArea} (${min}).`;
  }
}

function renderWheel() {
  const canvas = document.getElementById('wol-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2;
  const maxR = W/2 - 30;
  const n = WOL_AREAS.length;
  ctx.clearRect(0, 0, W, H);

  const colors = WOL_AREAS.map(a => a.color);

  // Draw grid rings
  for (let r = 1; r <= 5; r++) {
    ctx.beginPath();
    for (let i = 0; i < n; i++) {
      const angle = (i / n) * Math.PI * 2 - Math.PI/2;
      const x = cx + Math.cos(angle) * (maxR * r/5);
      const y = cy + Math.sin(angle) * (maxR * r/5);
      i === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.closePath();
    ctx.strokeStyle = 'rgba(124,58,237,0.2)';
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // Draw spokes
  for (let i = 0; i < n; i++) {
    const angle = (i / n) * Math.PI * 2 - Math.PI/2;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(angle)*maxR, cy + Math.sin(angle)*maxR);
    ctx.strokeStyle = 'rgba(124,58,237,0.15)';
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // Draw filled polygon
  ctx.beginPath();
  for (let i = 0; i < n; i++) {
    const angle = (i / n) * Math.PI * 2 - Math.PI/2;
    const r = (state.wheel[i] / 5) * maxR;
    const x = cx + Math.cos(angle) * r;
    const y = cy + Math.sin(angle) * r;
    i === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(124,58,237,0.15)';
  ctx.fill();
  ctx.strokeStyle = '#7C3AED';
  ctx.lineWidth = 2;
  ctx.stroke();

  // Draw dots
  for (let i = 0; i < n; i++) {
    const angle = (i / n) * Math.PI * 2 - Math.PI/2;
    const r = (state.wheel[i] / 5) * maxR;
    const x = cx + Math.cos(angle) * r;
    const y = cy + Math.sin(angle) * r;
    ctx.beginPath();
    ctx.arc(x, y, 5, 0, Math.PI*2);
    ctx.fillStyle = colors[i];
    ctx.strokeStyle = '#0D0B1E';
    ctx.lineWidth = 1.5;
    ctx.fill();
    ctx.stroke();
  }

  // Labels
  ctx.font = 'bold 9px Mulish, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  for (let i = 0; i < n; i++) {
    const angle = (i / n) * Math.PI * 2 - Math.PI/2;
    const lx = cx + Math.cos(angle) * (maxR + 20);
    const ly = cy + Math.sin(angle) * (maxR + 20);
    ctx.fillStyle = colors[i];
    ctx.fillText(WOL_AREAS[i].label, lx, ly);
  }
}

function saveWheelSnapshot() {
  const entry = {
    date: new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
    values: [...state.wheel],
    avg: (state.wheel.reduce((a,b)=>a+b,0)/state.wheel.length).toFixed(1)
  };
  state.wheelHistory.unshift(entry);
  addXP(20, 'Wheel of Life check-in completed 🎡');
  renderHistoryTable();
  saveState();
}

function renderHistoryTable() {
  const body = document.getElementById('history-body');
  if (!state.wheelHistory.length) {
    body.innerHTML = `<tr><td colspan="12" style="color:rgba(167,139,250,0.4);font-style:italic;font-size:0.72rem;padding:1rem;font-family:'Space Mono',monospace;">No check-ins yet.</td></tr>`;
    return;
  }
  const colors = WOL_AREAS.map(a => a.color);
  body.innerHTML = state.wheelHistory.map((h, i) => `
    <tr>
      <td style="color:rgba(167,139,250,0.5);font-family:'Space Mono',monospace;font-size:0.6rem">${h.date}</td>
      ${h.values.map((v,j) => `<td><span class="score-dot" style="background:${colors[j]}">${v}</span></td>`).join('')}
      <td><strong style="color:#D97706">${h.avg}</strong></td>
      <td><button class="history-delete-btn" onclick="deleteWheelEntry(${i})" title="Remove this entry">✕</button></td>
    </tr>
  `).join('');
}

function deleteWheelEntry(i) {
  state.wheelHistory.splice(i, 1);
  renderHistoryTable();
  saveState();
}

// ── EXPORT / IMPORT ──
function exportAllData() {
  const snapshot = {
    exportedAt: new Date().toISOString(),
    version: 1,
    state: JSON.parse(JSON.stringify(state)),
  };
  snapshot.state.freshEntries = freshEntries;
  const blob = new Blob([JSON.stringify(snapshot, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'questlabs_backup_' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
}

function importAllData(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const parsed = JSON.parse(e.target.result);
      // Accept both raw state or a wrapped snapshot
      const incoming = parsed.state || parsed;
      Object.assign(state, incoming);
      if (incoming.freshEntries) freshEntries = incoming.freshEntries;
      if (!state.archive) state.archive = [];
      if (!state.wheelHistory) state.wheelHistory = [];
      if (!state.xpLog) state.xpLog = [];
      if (!state.cells || !state.cells.length) state.cells = makeDefaultCells();
      saveState();
      renderQuestCard();
      renderArchive();
      renderWheelSliders();
      renderWheel();
      renderHistoryTable();
      updateWheelNotice();
      updateIdentity();
      alert('Import successful! Your data has been restored.');
    } catch(err) {
      alert('Could not read that file. Make sure it\'s a valid Quest Labs JSON export.');
    }
    // Reset the input so the same file can be re-imported if needed
    event.target.value = '';
  };
  reader.readAsText(file);
}


// ── PERSIST ──
function saveState() {
  fetch('/api/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      questCard: {
        name: state.name,
        xp: state.xp,
        xpLog: state.xpLog,
        cells: state.cells,
        archive: state.archive,
      },
      wheelOfLife: {
        current: state.wheel,
        history: state.wheelHistory,
      },
      freshCheckin: {
        entries: freshEntries,
      },
    }),
  }).catch(() => {});
}

async function loadStateFromDB() {
  try {
    const res = await fetch('/api/load');
    const db = await res.json();
    if (db.questCard) {
      state.name    = db.questCard.name  || '';
      state.xp      = db.questCard.xp    || 0;
      state.xpLog   = db.questCard.xpLog || [];
      state.archive = db.questCard.archive || [];
      if (db.questCard.cells && db.questCard.cells.length) {
        state.cells = db.questCard.cells;
      }
    }
    if (db.wheelOfLife) {
      if (db.wheelOfLife.current && db.wheelOfLife.current.length === WOL_AREAS.length) {
        state.wheel = db.wheelOfLife.current;
      }
      state.wheelHistory = db.wheelOfLife.history || [];
    }
    if (db.freshCheckin) {
      freshEntries = db.freshCheckin.entries || [];
    }
    if (db.questorProfile) {
      Object.assign(profileState, db.questorProfile);
      if (db.questorProfile.about) Object.assign(profileState.about, db.questorProfile.about);
    }
  } catch (e) {
    console.warn('Could not reach /api/load — using default state');
  }
}

