async function openUpdatesModal() {
  document.getElementById('updates-overlay').style.display = 'flex';
  try {
    const res = await fetch('/api/version');
    const { version } = await res.json();
    document.getElementById('updates-version').textContent = `v${version}`;
  } catch (_) {
    document.getElementById('updates-version').textContent = 'unknown';
  }
}

function closeUpdatesModal() {
  document.getElementById('updates-overlay').style.display = 'none';
}

// ── QUESTOR PROFILE ──
let profileState = {
  portrait: '',
  iAm: '',
  about: { age: '', faveFood: '', faveMovie: '', faveSubject: '', dreamJob: '', whoIAdmire: '' },
  q1: '', q2: '', q3: '', q4: '', q5: '', q6: '', q7: '',
};

function saveProfile() {
  fetch('/api/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ questorProfile: profileState }),
  }).catch(() => {});
}

function renderProfile() {
  // Stats from quest card state
  const level = Math.floor(state.xp / 500) + 1;
  document.getElementById('qp-profile-name').textContent = state.name || 'Questor';
  document.getElementById('qp-profile-level').textContent = level;
  document.getElementById('qp-profile-xp').textContent = state.xp;

  // Portrait
  if (profileState.portrait) {
    const img = document.getElementById('qp-portrait-img');
    img.src = `/portraits/${profileState.portrait}`;
    img.style.display = 'block';
    document.getElementById('qp-portrait-placeholder').style.display = 'none';
  }
}

function initProfileFields() {
  document.querySelectorAll('.qp-inline-field').forEach(el => {
    const key = el.dataset.key;
    // Set initial value
    const val = key.startsWith('about.')
      ? profileState.about[key.slice(6)]
      : profileState[key];
    if (val) el.textContent = val;

    el.addEventListener('blur', () => {
      const trimmed = el.textContent.trim();
      if (key.startsWith('about.')) {
        profileState.about[key.slice(6)] = trimmed;
      } else {
        profileState[key] = trimmed;
      }
      saveProfile();
    });

    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); el.blur(); }
      if (e.key === 'Escape') { el.blur(); }
    });
  });
}

async function handlePortraitUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  const formData = new FormData();
  formData.append('portrait', file);
  try {
    const res = await fetch('/api/upload-portrait', { method: 'POST', body: formData });
    const { ok, filename } = await res.json();
    if (ok) {
      profileState.portrait = filename;
      const img = document.getElementById('qp-portrait-img');
      img.src = `/portraits/${filename}?t=${Date.now()}`;
      img.style.display = 'block';
      document.getElementById('qp-portrait-placeholder').style.display = 'none';
      saveProfile();
    }
  } catch (e) {
    console.warn('Portrait upload failed', e);
  }
  event.target.value = '';
}

// ── BOOT ──
window.addEventListener('load', async () => {
  await init();
  renderArchive();
  if (state.wheelHistory.length) renderHistoryTable();
  updateWheelNotice();
  freshBuildDims();
  freshRenderMadlib();
  renderProfile();
  initProfileFields();
});

// ── FRESH CHECK-IN ──
const FRESH_DIMS = [
  { key:'F', name:'Focus',         desc:'Clarity, attention, presence',                      color:'#b05e3a', light:'rgba(176,94,58,0.15)' },
  { key:'R', name:'Relationships', desc:'Connection, trust, belonging',                      color:'#4a6fa5', light:'rgba(74,111,165,0.15)' },
  { key:'E', name:'Energy',        desc:'Physical vitality, rest, capacity',                 color:'#4a8c6e', light:'rgba(74,140,110,0.15)' },
  { key:'S', name:'Stimuli',       desc:"What you're taking in — nourishing or depleting?", color:'#8c6a2e', light:'rgba(140,106,46,0.15)' },
  { key:'H', name:'Habits',        desc:'Routines, rhythms, practices',                      color:'#7a4e8c', light:'rgba(122,78,140,0.15)' },
];

let freshVals = { F:5, R:5, E:5, S:5, H:5 };
let freshTier  = 'good';
let freshEntries = [];

function freshBuildDims() {
  const c = document.getElementById('fresh-dims-container');
  if (!c) return;
  c.innerHTML = FRESH_DIMS.map(d => `
    <div class="fresh-dim-card">
      <div class="fresh-dim-accent" style="background:${d.color}"></div>
      <div class="fresh-dim-top">
        <div class="fresh-dim-badge" style="background:${d.light};color:${d.color}">${d.key}</div>
        <div class="fresh-dim-meta">
          <div class="fresh-dim-name">${d.name}</div>
          <div class="fresh-dim-desc">${d.desc}</div>
        </div>
        <div class="fresh-dim-val" id="fresh-val-${d.key}" style="color:${d.color}">${freshVals[d.key]}</div>
      </div>
      <div class="fresh-slider-row">
        <span class="fresh-tick">1</span>
        <input type="range" min="1" max="10" step="1" value="${freshVals[d.key]}"
          style="flex:1;-webkit-appearance:none;appearance:none;height:4px;border-radius:2px;outline:none;cursor:pointer;background:linear-gradient(to right,${d.light} 0%,${d.color} 100%)"
          oninput="freshUpdate('${d.key}', this.value)">
        <span class="fresh-tick right">10</span>
      </div>
    </div>
  `).join('');
}

function freshUpdate(key, v) {
  freshVals[key] = parseInt(v);
  document.getElementById('fresh-val-' + key).textContent = v;
  freshRenderMadlib();
}

const freshPhrases = {
  F: v => v<=3 ? 'scattered and hard to pin down'          : v<=6 ? 'present enough to move forward'               : 'clear and well-directed',
  R: v => v<=3 ? 'a bit isolated'                          : v<=6 ? 'reasonably connected'                          : 'held and supported',
  E: v => v<=3 ? 'running on fumes'                        : v<=6 ? 'holding steady'                                : 'fueled and ready',
  S: v => v<=3 ? 'overwhelmed by noise'                    : v<=6 ? 'navigating a mixed-signal environment'          : "nourished by what I'm taking in",
  H: v => v<=3 ? 'off my rhythms'                          : v<=6 ? 'loosely tethered to my routines'               : 'grounded in solid practices',
};

const freshTemplates = {
  good:   (f,r,e,s,h) => `Right now, my focus feels <span class="fhighlight">${f}</span> and my energy is <span class="fhighlight">${e}</span>. Relationships feel <span class="fhighlight">${r}</span>, and I'm <span class="fhighlight">${s}</span>. My habits are <span class="fhighlight">${h}</span>. <em>Good enough</em> looks like honoring where I actually am today.`,
  better: (f,r,e,s,h) => `Today I'm <span class="fhighlight">${e}</span> with focus that is <span class="fhighlight">${f}</span>. Connection feels <span class="fhighlight">${r}</span>, stimuli are <span class="fhighlight">${s}</span>, and habits are <span class="fhighlight">${h}</span>. <em>Better</em> means one intentional act of care — for myself or someone else.`,
  best:   (f,r,e,s,h) => `At my best, I bring <span class="fhighlight">${f}</span> focus and <span class="fhighlight">${e}</span> energy. I feel <span class="fhighlight">${r}</span>, <span class="fhighlight">${s}</span>, and <span class="fhighlight">${h}</span>. <em>Best</em> is the version of today where I'm fully present, moving from my values, and trusting the process.`,
};

function freshRenderMadlib() {
  const el = document.getElementById('fresh-madlib-text');
  if (!el) return;
  el.innerHTML = freshTemplates[freshTier](
    freshPhrases.F(freshVals.F), freshPhrases.R(freshVals.R), freshPhrases.E(freshVals.E),
    freshPhrases.S(freshVals.S), freshPhrases.H(freshVals.H)
  );
}

function freshSetTier(t, btn) {
  freshTier = t;
  document.querySelectorAll('.fresh-tier-pill').forEach(p => {
    p.className = 'fresh-tier-pill ft-' + p.dataset.tier + (p.dataset.tier === t ? ' active' : '');
  });
  freshRenderMadlib();
}

function freshSubmitEntry() {
  const now = new Date();
  const avg = Math.round((freshVals.F + freshVals.R + freshVals.E + freshVals.S + freshVals.H) / 5);
  freshEntries.push({
    id: freshEntries.length + 1,
    time: now.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}),
    timestamp: now.toISOString(),
    ...freshVals, avg, tier: freshTier,
    madlib: document.getElementById('fresh-madlib-text').innerText,
  });
  addXP(20, 'FRESH check-in logged ✓');
  const toast = document.getElementById('fresh-toast');
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2000);
  freshSyncDelta();
}

function freshShowPanel(p, btn) {
  document.querySelectorAll('.fresh-panel').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.fresh-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('fresh-panel-' + p).classList.add('active');
  btn.classList.add('active');
  if (p === 'delta') freshSyncDelta();
}

function freshSyncDelta() {
  const noData  = document.getElementById('fresh-delta-no-data');
  const content = document.getElementById('fresh-delta-content');
  if (!noData || !content) return;
  if (freshEntries.length === 0) { noData.style.display = ''; content.style.display = 'none'; return; }
  noData.style.display = 'none';
  content.style.display = 'block';
  freshPopulateSelects();
  freshRenderBumpChart();
  freshRenderDelta();
  freshRenderLog();
}

function freshPopulateSelects() {
  ['fresh-sel-from', 'fresh-sel-to'].forEach((id, idx) => {
    const sel = document.getElementById(id);
    sel.innerHTML = freshEntries.map((e, i) => `<option value="${i}">#${e.id} · ${e.time} · avg ${e.avg}</option>`).join('');
    if (freshEntries.length >= 2 && idx === 0) sel.value = freshEntries.length - 2;
    if (idx === 1) sel.value = freshEntries.length - 1;
  });
}

function freshRenderBumpChart() {
  const svg = document.getElementById('freshBumpSvg');
  if (!svg) return;
  const W = Math.max(svg.parentElement.clientWidth - 40, 200);
  const H = 200, padL = 28, padR = 28, padT = 16, padB = 24;
  const innerW = W - padL - padR, innerH = H - padT - padB;
  const n = freshEntries.length;
  const xPos = i => n === 1 ? padL + innerW / 2 : padL + (i / (n - 1)) * innerW;
  const yPos = v => padT + innerH - ((v - 1) / 9) * innerH;
  const HEX = { F:'#b05e3a', R:'#4a6fa5', E:'#4a8c6e', S:'#8c6a2e', H:'#7a4e8c' };

  let s = `<svg id="freshBumpSvg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" style="width:100%;overflow:visible">`;
  [2,4,6,8,10].forEach(v => {
    const y = yPos(v);
    s += `<line x1="${padL}" x2="${padL+innerW}" y1="${y}" y2="${y}" stroke="rgba(167,139,250,0.1)" stroke-width="0.5"/>`;
    s += `<text x="${padL-4}" y="${y+4}" font-size="8" fill="rgba(167,139,250,0.35)" text-anchor="end" font-family="Space Mono,monospace">${v}</text>`;
  });
  freshEntries.forEach((e, i) => {
    s += `<text x="${xPos(i)}" y="${H-4}" font-size="8" fill="rgba(167,139,250,0.35)" text-anchor="middle" font-family="Space Mono,monospace">#${e.id}</text>`;
  });
  FRESH_DIMS.forEach(d => {
    const hex = HEX[d.key];
    if (n === 1) { s += `<circle cx="${xPos(0)}" cy="${yPos(freshEntries[0][d.key])}" r="5" fill="${hex}" opacity="0.85"/>`; return; }
    let path = '';
    freshEntries.forEach((e, i) => {
      const x = xPos(i), y = yPos(e[d.key]);
      if (i === 0) { path += `M ${x} ${y}`; }
      else { const px = xPos(i-1), py = yPos(freshEntries[i-1][d.key]), cx2 = (px+x)/2; path += ` C ${cx2} ${py} ${cx2} ${y} ${x} ${y}`; }
    });
    s += `<path d="${path}" fill="none" stroke="${hex}" stroke-width="2" opacity="0.7"/>`;
    freshEntries.forEach((e, i) => { s += `<circle cx="${xPos(i)}" cy="${yPos(e[d.key])}" r="4" fill="${hex}" opacity="0.9"/>`; });
  });
  s += `</svg>`;
  svg.outerHTML = s;
}

function freshRenderDelta() {
  const fromIdx = parseInt(document.getElementById('fresh-sel-from').value);
  const toIdx   = parseInt(document.getElementById('fresh-sel-to').value);
  const from = freshEntries[fromIdx], to = freshEntries[toIdx];
  if (!from || !to) return;

  document.getElementById('fresh-delta-bars').innerHTML = FRESH_DIMS.map(d => {
    const a = from[d.key], b = to[d.key], delta = b - a;
    const arrow = delta > 0 ? '↑' : delta < 0 ? '↓' : '→';
    const arrowColor = delta > 0 ? '#4a8c6e' : delta < 0 ? '#c05040' : 'rgba(167,139,250,0.4)';
    return `<div class="fresh-delta-item">
      <div class="fresh-delta-badge" style="background:${d.light};color:${d.color}">${d.key}</div>
      <div class="fresh-delta-dim-name">${d.name}</div>
      <div class="fresh-delta-track"><div class="fresh-delta-bar-fill" style="width:${(b/10)*100}%;background:${d.color};opacity:0.7"></div></div>
      <div class="fresh-delta-nums">${a} → ${b}</div>
      <div class="fresh-delta-arrow" style="color:${arrowColor}">${arrow}${Math.abs(delta) > 0 ? ' ' + Math.abs(delta) : ''}</div>
    </div>`;
  }).join('');

  const deltas  = FRESH_DIMS.map(d => ({ name: d.name, delta: to[d.key] - from[d.key] }));
  const gains   = deltas.filter(d => d.delta > 0).sort((a,b) => b.delta - a.delta);
  const drops   = deltas.filter(d => d.delta < 0).sort((a,b) => a.delta - b.delta);
  const avgDelta = Math.round((to.F+to.R+to.E+to.S+to.H - from.F-from.R-from.E-from.S-from.H) / 5 * 10) / 10;
  let text = '';
  if (!gains.length && !drops.length) {
    text = 'Everything held steady between these two check-ins. Stability can be its own kind of wisdom.';
  } else {
    if (gains.length) text += `<strong>${gains[0].name}</strong> showed the biggest upward movement (+${gains[0].delta}${gains.length > 1 ? `, along with ${gains.slice(1).map(g=>g.name).join(', ')}` : ''}). `;
    if (drops.length) text += `<strong>${drops[0].name}</strong> pulled back the most (${drops[0].delta}${drops.length > 1 ? `, joined by ${drops.slice(1).map(d=>d.name).join(', ')}` : ''}). `;
    text += avgDelta > 0 ? `Overall, you're moving <em>upward</em> — average shift of +${avgDelta}.`
           : avgDelta < 0 ? `Overall, the system contracted — average shift of ${avgDelta}. Worth a moment of honest inquiry.`
           : `The system balanced out — what rose and what dropped offset each other.`;
  }
  document.getElementById('fresh-delta-narrative').innerHTML = text;
}

function freshRenderLog() {
  const tColors = { good: '#4a8c6e', better: '#4a6fa5', best: '#7a4e8c' };
  document.getElementById('fresh-log-body').innerHTML = freshEntries.slice().reverse().map(e =>
    `<tr><td>${e.id}</td><td>${e.time}</td><td>${e.F}</td><td>${e.R}</td><td>${e.E}</td><td>${e.S}</td><td>${e.H}</td><td>${e.avg}</td><td style="color:${tColors[e.tier]}">${e.tier}</td></tr>`
  ).join('');
}

function freshExportData() {
  const blob = new Blob([JSON.stringify(freshEntries, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'FRESH_checkins_' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
}
</script>

</Layout>
