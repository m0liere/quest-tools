  /* ── QUESTOR PROFILE ── */
  .qp-card {
    display: grid;
    grid-template-columns: 36px 1fr 1.4fr;
    grid-template-rows: auto;
    border: 1px solid rgba(124,58,237,0.3);
    background: rgba(13,11,30,0.85);
    min-height: 600px;
    overflow: hidden;
  }

  /* Spine */
  .qp-spine {
    grid-row: 1;
    grid-column: 1;
    background: #7C3AED;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 0;
  }

  /* Left panel */
  .qp-left {
    grid-column: 2;
    border-right: 1px solid rgba(124,58,237,0.2);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Portrait */
  .qp-portrait-wrap {
    width: 100%;
    aspect-ratio: 1;
    background: rgba(30,27,75,0.6);
    border-bottom: 1px solid rgba(124,58,237,0.15);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: background 0.2s;
  }
  .qp-portrait-wrap:hover { background: rgba(124,58,237,0.1); }
  .qp-portrait-wrap:hover .qp-portrait-placeholder { opacity: 0.7; }

  .qp-portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .qp-portrait-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    transition: opacity 0.2s;
  }

  /* "I Am" block */
  .qp-iam-wrap {
    padding: 0.75rem 1rem 0.5rem;
    border-bottom: 1px solid rgba(124,58,237,0.1);
  }

  /* Name / Level / XP */
  .qp-name-level {
    padding: 0.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border-bottom: 1px solid rgba(124,58,237,0.1);
  }
  .qp-stat-val {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: #A78BFA;
  }

  /* About Me */
  .qp-about {
    padding: 0.75rem 1rem 1rem;
    flex: 1;
  }
  .qp-about-title {
    font-family: 'Space Mono', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(124,58,237,0.8);
    margin-bottom: 0.6rem;
    border-bottom: 1px solid rgba(124,58,237,0.2);
    padding-bottom: 0.3rem;
  }
  .qp-about-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .qp-about-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.48rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.5);
    white-space: nowrap;
    min-width: 72px;
  }

  /* Right panel */
  .qp-right {
    grid-column: 3;
    display: flex;
    flex-direction: column;
  }

  .qp-q-item {
    flex: 1;
    border-bottom: 1px solid rgba(124,58,237,0.15);
    display: flex;
    flex-direction: column;
  }
  .qp-q-item:last-child { border-bottom: none; }

  .qp-q-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.75rem;
    background: rgba(30,27,75,0.5);
    border-bottom: 1px solid rgba(124,58,237,0.1);
  }
  .qp-q-title {
    font-family: 'Playfair Display', serif;
    font-size: 0.75rem;
    font-style: italic;
    color: #EDE9FE;
  }
  .qp-q-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }
  .qp-q-body {
    flex: 1;
    padding: 0.5rem 0.75rem;
  }

  /* Shared field label */
  .qp-field-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.48rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.5);
    margin-bottom: 0.2rem;
    display: block;
  }

  /* Editable inline fields */
  .qp-inline-field {
    font-family: 'Mulish', sans-serif;
    font-size: 0.78rem;
    color: rgba(253,252,255,0.85);
    line-height: 1.5;
    outline: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
    min-height: 1.2em;
    cursor: text;
  }
  .qp-inline-field:focus {
    border-bottom-color: rgba(124,58,237,0.5);
  }
  .qp-inline-field:empty::before {
    content: attr(data-placeholder);
    color: rgba(167,139,250,0.25);
    pointer-events: none;
  }

  @media (max-width: 700px) {
    .qp-card {
      grid-template-columns: 28px 1fr;
      grid-template-rows: auto auto;
    }
    .qp-left { grid-column: 2; border-right: none; border-bottom: 1px solid rgba(124,58,237,0.2); }
    .qp-right { grid-column: 2; }
