}

// ── EXPORT / IMPORT ──
function exportAllData() {
  const snapshot = {
    exportedAt: new Date().toISOString(),
    version: 1,
    state: JSON.parse(JSON.stringify(state)),
  };
  snapshot.state.freshEntries = freshEntries;
  const blob = new Blob([JSON.stringify(snapshot, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'questlabs_backup_' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
}

function importAllData(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const parsed = JSON.parse(e.target.result);
      // Accept both raw state or a wrapped snapshot
      const incoming = parsed.state || parsed;
      Object.assign(state, incoming);
      if (incoming.freshEntries) freshEntries = incoming.freshEntries;
      if (!state.archive) state.archive = [];
      if (!state.wheelHistory) state.wheelHistory = [];
      if (!state.xpLog) state.xpLog = [];
      if (!state.quests) state.quests = [];
      if (!state.cells || !state.cells.length) state.cells = makeDefaultCells();
      saveState();
      renderQuestCard();
      renderArchive();
      renderWheelSliders();
      renderWheel();
      renderHistoryTable();
      updateWheelNotice();
      updateIdentity();
      alert('Import successful! Your data has been restored.');
    } catch(err) {
      alert('Could not read that file. Make sure it\'s a valid Quest Labs JSON export.');
    }
    // Reset the input so the same file can be re-imported if needed
    event.target.value = '';
  };
  reader.readAsText(file);
}


// ── PERSIST ──
function saveState() {
  fetch('/api/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      questCard: {
        name: state.name,
        xp: state.xp,
        xpLog: state.xpLog,
        cells: state.cells,
        archive: state.archive,
        quests: state.quests,
      },
      wheelOfLife: {
        current: state.wheel,
        history: state.wheelHistory,
      },
      freshCheckin: {
        entries: freshEntries,
      },
    }),
  }).catch(() => {});
}

async function loadStateFromDB() {
  try {
    const res = await fetch('/api/load');
    const db = await res.json();
    if (db.questCard) {
      state.name    = db.questCard.name  || '';
      state.xp      = db.questCard.xp    || 0;
      state.xpLog   = db.questCard.xpLog || [];
      state.archive = db.questCard.archive || [];
      if (db.questCard.cells && db.questCard.cells.length) {
        state.cells = db.questCard.cells;
      }
      state.quests = db.questCard.quests || [];
    }
    if (db.wheelOfLife) {
      if (db.wheelOfLife.current && db.wheelOfLife.current.length === WOL_AREAS.length) {
        state.wheel = db.wheelOfLife.current;
      }
      state.wheelHistory = db.wheelOfLife.history || [];
    }
    if (db.freshCheckin) {
      freshEntries = db.freshCheckin.entries || [];
    }
    if (db.questorProfile) {
      Object.assign(profileState, db.questorProfile);
      if (db.questorProfile.about) Object.assign(profileState.about, db.questorProfile.about);
    }
  } catch (e) {
    console.warn('Could not reach /api/load — using default state');
  }
}

