  iAm: '',
  about: { age: '', faveFood: '', faveMovie: '', faveSubject: '', dreamJob: '', whoIAdmire: '' },
  q1: '', q2: '', q3: '', q4: '', q5: '', q6: '', q7: '',
};

function saveProfile() {
  fetch('/api/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ questorProfile: profileState }),
  }).catch(() => {});
