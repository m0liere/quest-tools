---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quest Labs — Quest Cards" currentPage="/">

<style is:global>
  :root {
    --ql:     #7C3AED;
    --school: #0D9488;
    --work:   #BE123C;
    --home:   #D97706;
    --joy:    #A78BFA;

    --s1: #7C3AED;
    --s2: #0D9488;
    --s3: #BE123C;
    --s4: #D97706;
    --s5: #A78BFA;
  }

  .page-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    position: relative;
    z-index: 1;
  }

  /* Internal tabs */
  .tab-nav {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 2rem;
    padding: 0.75rem 1rem;
    background: rgba(30,27,75,0.6);
    border: 1px solid rgba(124,58,237,0.2);
    border-radius: 4px;
  }

  .nav-util-group {
    margin-left: auto;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .nav-util-btn {
    position: relative;
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgba(167,139,250,0.25);
    background: transparent;
    color: rgba(167,139,250,0.6);
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 2px;
  }
  .nav-util-btn:hover {
    border-color: rgba(167,139,250,0.6);
    color: #EDE9FE;
    background: rgba(124,58,237,0.1);
  }
  .nav-util-btn.export-btn { border-color: rgba(13,148,136,0.3); color: rgba(204,251,241,0.6); }
  .nav-util-btn.export-btn:hover { border-color: #0D9488; color: #CCFBF1; background: rgba(13,148,136,0.12); }
  .nav-util-btn.import-btn { border-color: rgba(217,119,6,0.3); color: rgba(253,230,138,0.6); }
  .nav-util-btn.import-btn:hover { border-color: #D97706; color: #FEF3C7; background: rgba(217,119,6,0.12); }

  /* Tooltips */
  [data-tooltip] { position: relative; }
  [data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 220px;
    background: rgba(13,11,30,0.97);
    border: 1px solid rgba(124,58,237,0.3);
    color: rgba(237,233,254,0.85);
    font-family: 'Mulish', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1.5;
    padding: 0.6rem 0.75rem;
    border-radius: 4px;
    white-space: pre-wrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }
  [data-tooltip]:hover::after { opacity: 1; }

  .nav-tab {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(167,139,250,0.3);
    background: transparent;
    color: #A78BFA;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 2px;
  }

  .nav-tab:hover {
    border-color: #7C3AED;
    background: rgba(124,58,237,0.12);
    color: #EDE9FE;
  }

  .nav-tab.active {
    background: rgba(124,58,237,0.25);
    border-color: #7C3AED;
    color: #EDE9FE;
  }

  .nav-xp {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    color: #D97706;
    margin-left: auto;
    align-self: center;
  }

  /* Sections */
  .section { display: none; }
  .section.active { display: block; }

  /* ── QUEST CARD ── */
  .qc-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(124,58,237,0.2);
  }

  .qc-name-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .qc-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-style: italic;
    color: #EDE9FE;
  }

  .qc-date {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    color: rgba(167,139,250,0.85);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* XP bar */
  .xp-bar-wrap {
    background: rgba(30,27,75,0.6);
    border: 1px solid rgba(124,58,237,0.25);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }

  .xp-bar-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.85);
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: space-between;
  }

  .xp-track {
    height: 10px;
    background: rgba(124,58,237,0.15);
    border-radius: 999px;
    overflow: hidden;
    border: 1px solid rgba(124,58,237,0.3);
  }

  .xp-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--violet), var(--lavender));
    border-radius: 999px;
    transition: width 0.5s ease;
    width: 0%;
  }

  .xp-pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .xp-pill {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    padding: 0.26rem 0.78rem;
    border-radius: 999px;
    border: 1px solid;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s;
    background: transparent;
  }

  .xp-pill:hover { transform: scale(1.05); opacity: 0.85; }

  .assist-wrap {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .assist-skin-select {
    font-size: 0.85rem;
    background: transparent;
    border: 1px solid rgba(217,119,6,0.4);
    border-radius: 999px;
    color: #D97706;
    padding: 0.1rem 0.3rem;
    cursor: pointer;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
    line-height: 1;
  }

  .assist-skin-select:hover { border-color: #D97706; }
  .assist-skin-select option { background: #1A0B2B; color: #f0ecf8; }

  /* Quest Card Board */
  .qc-board {
    background: rgba(13,11,30,0.8);
    border: 1px solid rgba(124,58,237,0.25);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .qc-columns {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }

  .col-header {
    padding: 0.75rem 0.5rem;
    text-align: center;
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: white;
    line-height: 1.3;
    border-right: 1px solid rgba(255,255,255,0.15);
  }

  .col-header:last-child { border-right: none; }
  .col-header.ql     { background: rgba(124,58,237,0.7); }
  .col-header.school { background: rgba(13,148,136,0.7); }
  .col-header.work   { background: rgba(190,18,60,0.7); }
  .col-header.home   { background: rgba(217,119,6,0.7); }
  .col-header.joy    { background: rgba(167,139,250,0.5); }

  .qc-grid {
    display: flex;
    align-items: flex-start;
    border-top: 1px solid rgba(124,58,237,0.2);
  }

  .qc-col-lane {
    flex: 1;
    min-height: 120px;
    border-right: 1px solid rgba(124,58,237,0.15);
    display: flex;
    flex-direction: column;
    transition: background 0.15s;
  }

  .qc-col-lane:last-child { border-right: none; }

  .qc-col-lane.drag-over {
    background: rgba(124,58,237,0.1);
    outline: 1px dashed rgba(124,58,237,0.45);
    outline-offset: -2px;
  }

  .qc-cell {
    border-bottom: 1px solid rgba(124,58,237,0.15);
    padding: 0.6rem 0.5rem;
    min-height: 72px;
    position: relative;
    cursor: grab;
    transition: background 0.15s;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.3rem;
  }

  .qc-cell:hover { background: rgba(124,58,237,0.08); }
  .qc-cell.dragging { opacity: 0.3; cursor: grabbing; }

  .qc-cell.done { background: rgba(124,58,237,0.12); }
  .qc-cell.ql-col.done    { background: rgba(124,58,237,0.18); }
  .qc-cell.school-col.done { background: rgba(13,148,136,0.15); }
  .qc-cell.work-col.done  { background: rgba(190,18,60,0.15); }
  .qc-cell.home-col.done  { background: rgba(217,119,6,0.15); }
  .qc-cell.joy-col.done   { background: rgba(167,139,250,0.18); }

  .cell-text {
    font-family: 'Mulish', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.3;
    color: rgba(253,252,255,0.85);
    pointer-events: none;
  }

  .cell-star {
    font-size: 0.98rem;
    opacity: 0;
    transition: opacity 0.2s;
    position: absolute;
    top: 4px; right: 4px;
    color: #D97706;
    pointer-events: none;
  }
  .qc-cell.done .cell-star { opacity: 1; }


  /* Overflow */
  .overflow-tasks {
    background: rgba(30,27,75,0.5);
    border: 1px solid rgba(124,58,237,0.2);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }

  .overflow-title {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.85);
    margin-bottom: 0.75rem;
  }

  .overflow-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 5px;
    min-height: 2.5rem;
    padding: 0.25rem 0;
    transition: background 0.15s;
  }

  .overflow-grid.drag-over {
    background: rgba(124,58,237,0.07);
    outline: 1px dashed rgba(124,58,237,0.4);
    outline-offset: 2px;
  }

  /* SP badge */
  .sp-badge {
    position: absolute;
    bottom: 4px; right: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    color: rgba(167,139,250,0.5);
    background: rgba(124,58,237,0.12);
    padding: 1px 4px;
    border-radius: 2px;
    line-height: 1.4;
    pointer-events: none;
  }

  /* Edit button on cards */
  .cell-edit-btn {
    position: absolute;
    top: 3px; right: 3px;
    width: 16px; height: 16px;
    background: rgba(124,58,237,0.2);
    border: none;
    border-radius: 2px;
    color: rgba(167,139,250,0.6);
    font-size: 0.5rem;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: all 0.15s;
    z-index: 2;
  }
  .qc-cell:hover .cell-edit-btn { display: flex; }
  .cell-edit-btn:hover { background: rgba(124,58,237,0.5); color: #EDE9FE; }

  /* Add card button (bottom of each column) */
  .col-add-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    width: 100%;
    padding: 0.5rem 0.6rem;
    background: transparent;
    border: none;
    color: rgba(167,139,250,0.35);
    font-family: 'Space Mono', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
    margin-top: auto;
  }
  .col-add-btn:hover {
    background: rgba(124,58,237,0.08);
    color: #A78BFA;
  }

  /* Add overflow button */
  .add-overflow {
    font-family: 'Space Mono', monospace;
    font-size: 0.52rem;
    border: 1px dashed rgba(124,58,237,0.6);
    background: transparent;
    cursor: pointer;
    color: rgba(167,139,250,0.7);
    transition: all 0.15s;
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .add-overflow:hover { border-color: #7C3AED; color: #A78BFA; }

  /* Level display */
  .qc-level {
    font-family: 'Space Mono', monospace;
    font-size: 0.73rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.85);
    margin-top: 0.2rem;
  }

  /* ── CARD EDITOR ── */
  .ce-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    backdrop-filter: blur(4px);
  }

  .ce-modal {
    background: #110E25;
    border: 1px solid rgba(124,58,237,0.4);
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ce-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(124,58,237,0.15);
  }

  .ce-header-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.56rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.5);
  }

  .ce-close {
    background: none;
    border: none;
    color: rgba(167,139,250,0.4);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 2px 4px;
    transition: color 0.15s;
  }
  .ce-close:hover { color: #EDE9FE; }

  .ce-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .ce-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.8);
    display: block;
    margin-bottom: 0.3rem;
  }

  .ce-input {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(124,58,237,0.25);
    color: #EDE9FE;
    font-family: 'Mulish', sans-serif;
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .ce-input:focus { border-color: rgba(124,58,237,0.7); }

  .ce-sp-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .ce-sp-btn {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    width: 34px; height: 34px;
    border: 1px solid rgba(124,58,237,0.3);
    background: transparent;
    color: rgba(167,139,250,0.6);
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ce-sp-btn:hover { border-color: #7C3AED; color: #EDE9FE; background: rgba(124,58,237,0.15); }
  .ce-sp-btn.active { background: rgba(124,58,237,0.4); border-color: #7C3AED; color: #EDE9FE; }

  .ce-sp-key {
    display: grid;
    grid-template-columns: 20px 1fr auto;
    gap: 2px 8px;
    padding: 0.6rem 0.75rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(124,58,237,0.1);
    border-radius: 2px;
  }
  .ce-sp-key-row {
    display: contents;
  }
  .ce-sp-key-row > span {
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    color: rgba(167,139,250,0.75);
    padding: 1px 0;
    align-self: center;
  }
  .ce-sp-key-row > span:first-child {
    font-weight: 700;
    color: rgba(167,139,250,0.95);
  }
  .ce-xp { color: rgba(217,119,6,0.6) !important; }

  .ce-textarea {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(124,58,237,0.25);
    color: #EDE9FE;
    font-family: 'Mulish', sans-serif;
    font-size: 0.82rem;
    line-height: 1.6;
    padding: 0.5rem 0.75rem;
    outline: none;
    resize: vertical;
    min-height: 80px;
    transition: border-color 0.2s;
  }
  .ce-textarea:focus { border-color: rgba(124,58,237,0.7); }

  .ce-footer {
    display: flex;
    gap: 0.6rem;
    padding: 0.85rem 1.25rem;
    border-top: 1px solid rgba(124,58,237,0.15);
  }

  .ce-save {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    padding: 0.5rem 1.25rem;
    background: rgba(124,58,237,0.5);
    border: 1px solid rgba(124,58,237,0.7);
    color: #EDE9FE;
    cursor: pointer;
    transition: all 0.15s;
  }
  .ce-save:hover { background: rgba(124,58,237,0.7); }

  .ce-cancel {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid rgba(124,58,237,0.2);
    color: rgba(167,139,250,0.5);
    cursor: pointer;
    transition: all 0.15s;
  }
  .ce-cancel:hover { border-color: rgba(124,58,237,0.5); color: #A78BFA; }

  /* ── WHEEL OF LIFE ── */
  .wol-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 700px) {
    .wol-wrap { grid-template-columns: 1fr; }
  }

  .wol-canvas-wrap {
    background: rgba(30,27,75,0.6);
    border: 1px solid rgba(124,58,237,0.25);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .wol-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-style: italic;
    color: #EDE9FE;
    margin-bottom: 0.25rem;
  }

  .wol-subtitle {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    color: rgba(167,139,250,0.5);
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  #wol-canvas {
    max-width: 320px;
    width: 100%;
  }

  .wol-sliders {
    background: rgba(30,27,75,0.6);
    border: 1px solid rgba(124,58,237,0.25);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wol-slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .wol-area-label {
    font-family: 'Mulish', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    min-width: 100px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #EDE9FE;
  }

  .wol-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .wol-slider {
    flex: 1;
    -webkit-appearance: none;
    height: 4px;
    border-radius: 999px;
    background: rgba(124,58,237,0.25);
    outline: none;
    cursor: pointer;
  }

  .wol-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: #7C3AED;
    border: 2px solid #EDE9FE;
    cursor: pointer;
  }

  .wol-val {
    font-family: 'Space Mono', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    min-width: 1.5rem;
    text-align: center;
    color: #A78BFA;
  }

  .wol-notice {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.85rem;
    color: rgba(167,139,250,0.6);
    border-top: 1px solid rgba(124,58,237,0.15);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
    min-height: 2rem;
  }

  .wol-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(124,58,237,0.3);
    color: #EDE9FE;
    border: 1px solid rgba(124,58,237,0.5);
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    margin-top: 1rem;
    transition: all 0.2s;
  }

  .wol-cta:hover { background: rgba(124,58,237,0.5); border-color: #7C3AED; }

  .wol-history {
    margin-top: 2rem;
    background: rgba(30,27,75,0.5);
    border: 1px solid rgba(124,58,237,0.2);
    padding: 1.25rem;
    grid-column: 1 / -1;
  }

  .history-title {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.5);
    margin-bottom: 1rem;
  }

  .history-table {
