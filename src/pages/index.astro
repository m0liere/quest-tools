<script is:inline>
// ══ DATA ══
const COLUMNS = [
  { id:'ql', label:'Quest Labs', color:'#7C3AED' },
  { id:'school', label:'School Work', color:'#0D9488' },
  { id:'work', label:'Work / Research', color:'#BE123C' },
  { id:'home', label:'Home', color:'#D97706' },
  { id:'joy', label:'Joy of Being', color:'#A78BFA' },
];

const SP_VALUES = [1, 2, 3, 5, 8, 13, 21];

// Default cells — empty board on first run
const DEFAULT_CELLS = [];


const WOL_AREAS = [
  { label: 'Digital Diet', color: '#7C3AED' },
  { label: 'Organization', color: '#0D9488' },
  { label: 'Friends', color: '#BE123C' },
  { label: 'Family', color: '#D97706' },
  { label: 'Relationships', color: '#EC4899' },
  { label: 'School-work', color: '#A78BFA' },
  { label: 'Fun / Play', color: '#CCFBF1' },
  { label: 'Health', color: '#FEF3C7' },
  { label: 'Growth', color: '#EDE9FE' },
];

const COL_CLASSES = ['ql-col','school-col','work-col','home-col','joy-col'];
const COL_ID_TO_IDX = { ql:0, school:1, work:2, home:3, joy:4 };
const COL_XP = [25, 20, 20, 15, 30];


// ══ STATE ══
// cells: [{ text, xp, done, col }]  col = 0-4 (grid column) or -1 (overflow)
let state = {
  name: '',
  xp: 0,
  xpLog: [],
  cells: [],
  overflow: [],   // kept for migration only
  archive: [],    // [{ text, xp, col, archivedAt }]
  wheel: [3,3,3,3,3,3,3,3,3],
  wheelHistory: [],
  quests: [],     // [{ id, name, desc }]
};

function makeDefaultCells() {
  return DEFAULT_CELLS.map(c => ({ ...c }));
}

// ── INIT ──
async function init() {
  state.cells = makeDefaultCells();
  await loadStateFromDB();
  renderQuestCard();
  renderWheelSliders();
  renderWheel();
  renderQuests();
  setDate();
  updateIdentity();
  initNameEdit();
}

function setDate() {
  const d = new Date();
  document.getElementById('qc-date').textContent = d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
}

// ── TABS ──
function switchTab(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}

// ── NAME (inline edit) ──
function initNameEdit() {
  const el = document.getElementById('qc-name');
  el.addEventListener('blur', () => {
    const name = el.textContent.trim();
    state.name = name || 'Questor';
    if (!name) el.textContent = 'Questor';
    saveState();
  });
  el.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); el.blur(); }
    if (e.key === 'Escape') { el.textContent = state.name || 'Questor'; el.blur(); }
  });
  // Close card editor on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeCardEditor(); closeQuestEditor(); }
    if (e.key === 'Enter' && document.getElementById('ce-overlay').style.display !== 'none') {
      if (document.activeElement === document.getElementById('ce-title')) saveCardEditor();
    }
  });
}

function updateIdentity() {
  const el = document.getElementById('qc-name');
  if (document.activeElement !== el) {
    el.textContent = state.name || 'Questor';
  }
  updateXPDisplay();
}

// ── QUEST CARD RENDER ──
function renderQuestCard() {
  const grid = document.getElementById('qc-grid');
  grid.innerHTML = '';

  // Build 5 column lanes
  for (let colIdx = 0; colIdx < 5; colIdx++) {
    const lane = document.createElement('div');
    lane.className = 'qc-col-lane';
    lane.dataset.col = colIdx;

    state.cells.forEach((cell, i) => {
      if (cell.col === colIdx) lane.appendChild(createGridCard(cell, i));
    });

    lane.addEventListener('dragover', e => { e.preventDefault(); lane.classList.add('drag-over'); });
    lane.addEventListener('dragleave', e => { if (!lane.contains(e.relatedTarget)) lane.classList.remove('drag-over'); });
    lane.addEventListener('drop', e => handleDropOnCol(e, colIdx));

    const addBtn = document.createElement('button');
    addBtn.className = 'col-add-btn';
    addBtn.innerHTML = '+ Add card';
    addBtn.onclick = () => addCardToColumn(colIdx);
    lane.appendChild(addBtn);

    grid.appendChild(lane);
  }

  renderOverflow();
  updateXPDisplay();
}

function createGridCard(cell, idx) {
  const div = document.createElement('div');
  const colIdx = cell.col >= 0 ? cell.col : 0;
  div.className = `qc-cell ${COL_CLASSES[colIdx]} ${cell.done ? 'done' : ''}`;
  div.dataset.idx = idx;
  div.draggable = true;
  const sp = cell.storyPoints || 1;
  const quest = cell.questId ? state.quests.find(q => q.id === cell.questId) : null;
  div.innerHTML = `
    <span class="cell-star">★</span>
    <button class="cell-edit-btn" title="Edit task">✎</button>
    ${quest ? `<div class="cell-quest-tag">${quest.name}</div>` : ''}
    <div class="cell-text">${cell.text}</div>
    <div class="sp-badge">SP ${sp}</div>
  `;

  div.addEventListener('click', e => {
    if (e.target.closest('.cell-edit-btn')) return;
    toggleCell(idx);
  });
  div.querySelector('.cell-edit-btn').addEventListener('click', e => {
    e.stopPropagation();
    openCardEditor(idx);
  });

  div.addEventListener('dragstart', e => {
    e.dataTransfer.setData('text/plain', JSON.stringify({ type: 'cell', idx }));
    e.dataTransfer.effectAllowed = 'move';
    setTimeout(() => div.classList.add('dragging'), 0);
  });
  div.addEventListener('dragend', () => {
    div.classList.remove('dragging');
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
  });

  return div;
}

function renderOverflow() {
  const og = document.getElementById('overflow-grid');
  og.innerHTML = '';

  state.cells.forEach((cell, i) => {
    if (cell.col !== -1) return;
    const card = document.createElement('div');
    const sp = cell.storyPoints || 1;
    card.className = `qc-cell ql-col ${cell.done ? 'done' : ''}`;
    card.style.cssText = 'border-color:rgba(124,58,237,0.2);background:rgba(124,58,237,0.05);';
    card.dataset.idx = i;
    card.draggable = true;
    const overflowQuest = cell.questId ? state.quests.find(q => q.id === cell.questId) : null;
    card.innerHTML = `
      <span class="cell-star">★</span>
      <button class="cell-edit-btn" title="Edit task">✎</button>
      ${overflowQuest ? `<div class="cell-quest-tag">${overflowQuest.name}</div>` : ''}
      <div class="cell-text">${cell.text}</div>
      <div class="sp-badge">SP ${sp}</div>
    `;

    card.addEventListener('click', e => {
      if (e.target.closest('.cell-edit-btn')) return;
      state.cells[i].done = !state.cells[i].done;
      const xpVal = (state.cells[i].storyPoints || 1) * 10;
      if (state.cells[i].done) {
        addXP(xpVal, state.cells[i].text);
      } else {
        state.xp = Math.max(0, state.xp - xpVal);
        updateXPDisplay();
      }
      renderQuestCard();
      saveState();
    });
    card.querySelector('.cell-edit-btn').addEventListener('click', e => {
      e.stopPropagation();
      openCardEditor(i);
    });

    card.addEventListener('dragstart', e => {
      e.dataTransfer.setData('text/plain', JSON.stringify({ type: 'cell', idx: i }));
      e.dataTransfer.effectAllowed = 'move';
      setTimeout(() => card.classList.add('dragging'), 0);
    });
    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    });

    og.appendChild(card);
  });

  const addBtn = document.createElement('button');
  addBtn.className = 'add-overflow';
  addBtn.textContent = '+ add card';
  addBtn.onclick = addOverflow;
  og.appendChild(addBtn);

  // Wire overflow drop zone
  og.addEventListener('dragover', e => { e.preventDefault(); og.classList.add('drag-over'); });
  og.addEventListener('dragleave', e => { if (!og.contains(e.relatedTarget)) og.classList.remove('drag-over'); });
  og.addEventListener('drop', e => handleDropOnOverflow(e));
}

function handleDropOnCol(e, targetCol) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  try {
    const data = JSON.parse(e.dataTransfer.getData('text/plain'));
    if (data.type === 'cell') {
      state.cells[data.idx].col = targetCol;
      renderQuestCard();
      saveState();
    }
  } catch(_) {}
}

function handleDropOnOverflow(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  try {
    const data = JSON.parse(e.dataTransfer.getData('text/plain'));
    if (data.type === 'cell' && state.cells[data.idx].col !== -1) {
      state.cells[data.idx].col = -1;
      renderQuestCard();
      saveState();
    }
  } catch(_) {}
}

function toggleCell(i) {
  state.cells[i].done = !state.cells[i].done;
  const xpVal = (state.cells[i].storyPoints || 1) * 10;
  if (state.cells[i].done) {
    addXP(xpVal, state.cells[i].text);
  } else {
    state.xp = Math.max(0, state.xp - xpVal);
    updateXPDisplay();
  }
  renderQuestCard();
  saveState();
}

// ── CARD EDITOR ──
let _editingIdx = null;
let _activeSP = 1;
let _isNewCard = false;

function addCardToColumn(col) {
  state.cells.push({ text: '', storyPoints: 1, xp: 10, description: '', done: false, col });
  renderQuestCard();
  openCardEditor(state.cells.length - 1, true);
}

function openCardEditor(idx, isNew = false) {
  _editingIdx = idx;
  _isNewCard = isNew;
  const cell = state.cells[idx];
  document.getElementById('ce-title').value = cell.text || '';
  document.getElementById('ce-title').placeholder = 'Task name';
  document.getElementById('ce-desc').value = cell.description || '';
  buildSPButtons(cell.storyPoints || 1);
  buildQuestSelect(cell.questId || null);
  document.getElementById('ce-overlay').style.display = 'flex';
  document.getElementById('ce-title').focus();
}

function buildQuestSelect(questId) {
  const sel = document.getElementById('ce-quest');
  sel.innerHTML = '<option value="">— No quest —</option>';
  state.quests.forEach(q => {
    const opt = document.createElement('option');
    opt.value = q.id;
    opt.textContent = q.name;
    if (q.id === questId) opt.selected = true;
    sel.appendChild(opt);
  });
}

function closeCardEditor() {
  if (_isNewCard && _editingIdx !== null) {
    state.cells.splice(_editingIdx, 1);
    renderQuestCard();
  }
  document.getElementById('ce-overlay').style.display = 'none';
  _editingIdx = null;
  _isNewCard = false;
}

function ceOverlayClick(e) {
  if (e.target === document.getElementById('ce-overlay')) closeCardEditor();
}

function buildSPButtons(activeSP) {
  _activeSP = activeSP;
  const row = document.getElementById('ce-sp-row');
  row.innerHTML = '';
  SP_VALUES.forEach(sp => {
    const btn = document.createElement('button');
    btn.className = 'ce-sp-btn' + (sp === activeSP ? ' active' : '');
    btn.textContent = sp;
    btn.dataset.sp = sp;
    btn.type = 'button';
    btn.onclick = () => {
      _activeSP = sp;
      row.querySelectorAll('.ce-sp-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.sp) === sp));
    };
    row.appendChild(btn);
  });
}

function saveCardEditor() {
  if (_editingIdx === null) return;
  const title = document.getElementById('ce-title').value.trim();
  if (!title) { closeCardEditor(); return; }
  const desc  = document.getElementById('ce-desc').value.trim();
  state.cells[_editingIdx].text        = title;
  state.cells[_editingIdx].description = desc;
  state.cells[_editingIdx].storyPoints = _activeSP;
  state.cells[_editingIdx].xp          = _activeSP * 10;
  state.cells[_editingIdx].questId     = document.getElementById('ce-quest').value || null;
  _isNewCard = false;
  renderQuestCard();
  saveState();
  closeCardEditor();
}

function addOverflow() {
  state.cells.push({ text: '', storyPoints: 1, xp: 10, description: '', done: false, col: -1 });
  renderQuestCard();
  openCardEditor(state.cells.length - 1, true);
}

// ── QUESTS ──
let _questEditingIdx = null;
let _questIsNew = false;

function renderQuests() {
  const list = document.getElementById('qst-list');
  if (!list) return;
  list.innerHTML = '';
  if (!state.quests || state.quests.length === 0) {
    list.innerHTML = '<div class="qst-empty"><div class="qst-empty-text">No quests yet — define your first epic below</div></div>';
    return;
  }
  state.quests.forEach((q, i) => {
    const associated = state.cells.filter(c => c.questId === q.id);
    const doneXP = associated.filter(c => c.done).reduce((sum, c) => sum + (c.xp || 0), 0);
    const card = document.createElement('div');
    card.className = 'qst-card';
    card.innerHTML = `
      <div class="qst-card-body">
        <div class="qst-card-name">${q.name}</div>
        ${q.desc ? `<div class="qst-card-desc">${q.desc}</div>` : ''}
        <div class="qst-card-meta">
          <div class="qst-meta-chip"><span>${associated.length}</span>tasks</div>
          <div class="qst-meta-chip"><span>${doneXP}</span>XP earned</div>
        </div>
      </div>
      <button class="qst-edit-btn" onclick="openQuestEditor(${i})">Edit ✎</button>
    `;
    list.appendChild(card);
  });
}

function addQuest() {
  if (!state.quests) state.quests = [];
  state.quests.push({ id: Date.now().toString(36), name: '', desc: '' });
  renderQuests();
  openQuestEditor(state.quests.length - 1, true);
}

function openQuestEditor(idx, isNew = false) {
  _questEditingIdx = idx;
  _questIsNew = isNew;
  const q = state.quests[idx];
  document.getElementById('qe-name').value = q.name || '';
  document.getElementById('qe-desc').value = q.desc || '';
  // Hide delete button for brand new quests
  document.getElementById('qe-delete-btn').style.visibility = isNew ? 'hidden' : 'visible';
  document.getElementById('qe-overlay').style.display = 'flex';
  document.getElementById('qe-name').focus();
}

function closeQuestEditor() {
  if (_questIsNew && _questEditingIdx !== null) {
    state.quests.splice(_questEditingIdx, 1);
    renderQuests();
  }
  document.getElementById('qe-overlay').style.display = 'none';
  _questEditingIdx = null;
  _questIsNew = false;
}

function saveQuestEditor() {
  if (_questEditingIdx === null) return;
  const name = document.getElementById('qe-name').value.trim();
  if (!name) { closeQuestEditor(); return; }
  state.quests[_questEditingIdx].name = name;
  state.quests[_questEditingIdx].desc = document.getElementById('qe-desc').value.trim();
  _questIsNew = false;
  document.getElementById('qe-overlay').style.display = 'none';
  _questEditingIdx = null;
  renderQuests();
  renderQuestCard();
  saveState();
}

function deleteQuest(idx) {
  if (idx === null || idx === undefined) return;
  const q = state.quests[idx];
  // Disassociate any task cards linked to this quest
  state.cells.forEach(c => { if (c.questId === q.id) c.questId = null; });
  state.quests.splice(idx, 1);
  _questIsNew = false;
  document.getElementById('qe-overlay').style.display = 'none';
  _questEditingIdx = null;
  renderQuests();
  renderQuestCard();
  saveState();
}

