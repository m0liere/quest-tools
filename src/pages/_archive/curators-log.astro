<script is:inline>
function saveAll() {
  const data = {};
  document.querySelectorAll('textarea, input[type=text]').forEach((el, i) => {
    data[`field_${i}`] = el.value;
  });
  try { localStorage.setItem('curators_log', JSON.stringify(data)); } catch(e) {}
}

function loadAll() {
  try {
    const data = JSON.parse(localStorage.getItem('curators_log') || '{}');
    document.querySelectorAll('textarea, input[type=text]').forEach((el, i) => {
      if (data[`field_${i}`]) el.value = data[`field_${i}`];
    });
  } catch(e) {}
}

document.querySelectorAll('textarea, input[type=text]').forEach(el => {
  el.addEventListener('input', saveAll);
});

loadAll();
</script>

